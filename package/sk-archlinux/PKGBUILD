# Maintainer: Skirmantas Kligys <Skirmantas.Kligys@gmail.com>

pkgname=waybar-git-sk
pkgver=r948.e9b0365
pkgrel=1
pkgdesc='Highly customizable Wayland bar for Sway and Wlroots based compositors (GIT), with SK patches'
arch=('x86_64')
url="https://github.com/Alexays/Waybar/"
license=('MIT')
provides=('waybar')
conflicts=('waybar')
depends=(
    'gammastep'
    'gtk-layer-shell'
    'gobject-introspection'
    'gtkmm3'
    'fmt'
    'jsoncpp'
    'libinput'
    'libnl>=3.0'
    'libsigc++>=2.0'
    'wayland'
    'libdbusmenu-gtk3'
    'libappindicator-gtk3'
    'libpulse'
    'spdlog'
)
makedepends=(
    'meson'
    'git'
)
optdepends=(
    'sway: Sway modules support'
    'libmpdclient: Mpd module support'
    'otf-font-awesome: Icons in the default configuration'
)
source=(
    "${pkgname}::git://github.com/Alexays/Waybar"
    'gammastep.patch'
    'calendar.patch'
)
sha256sums=(
    'SKIP'
    'bbf35e0737f8ed08ad7fc7f4148d0e87b33a680a1cb9dd194e6c4e9c4baaa7e6'
    'f78888c661221145c7048e4784698584de61d049176a267cff8576c1b1b354fb'
)

pkgver() {
    cd "${srcdir}/${pkgname}"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
    cd "${srcdir}/${pkgname}"
    patch --forward --strip=1 --input="${srcdir}/gammastep.patch"
    patch --forward --strip=1 --input="${srcdir}/calendar.patch"
}

build() {
    cd "${srcdir}/${pkgname}"
    rm -rf "${srcdir}/build"
    meson --prefix=/usr "${srcdir}/build"
    ninja -C "${srcdir}/build"
}

package() {
    DESTDIR="$pkgdir" ninja -C "${srcdir}/build" install
}
