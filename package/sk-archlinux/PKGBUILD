# Maintainer: Skirmantas Kligys <Skirmantas.Kligys@gmail.com>

pkgname=waybar-git-sk
pkgver=r948.e9b0365
pkgrel=1
pkgdesc='Highly customizable Wayland bar for Sway and Wlroots based compositors (GIT), with SK patches'
arch=('x86_64')
url="https://github.com/Alexays/Waybar/"
license=('MIT')
provides=('waybar')
conflicts=('waybar')
depends=(
    'gtkmm3'
    'libjsoncpp.so'
    'libsigc++'
    'fmt'
    'jack' 'libjack.so'
    'wayland'
    'libdate-tz.so'
    'libspdlog.so'
    'gtk-layer-shell'
    'libupower-glib.so'
    'upower'
    'libevdev'
    'libinput'
    'libpulse'
    'spdlog'
    'libnl'
    'libappindicator-gtk3'
    'libdbusmenu-gtk3'
    'libmpdclient'
    'libsndio.so'
    'libxkbcommon'
    'libwireplumber'
    'playerctl'
    # SK added:
    'gammastep'
    'ddcutil'
)
makedepends=(
    'cmake'
    'catch2'
    'meson'
    'scdoc' # For generating manpages
    'wayland-protocols'
)
backup=(
    etc/xdg/waybar/config
    etc/xdg/waybar/style.css
)
optdepends=(
    'otf-font-awesome: Icons in the default configuration'
)
source=(
    "${pkgname}::git+https://github.com/Alexays/Waybar#commit=d3b094503e4ae2cfbf35c264082a6812e0a4c771"
    'gammastep.patch'
    'ddcutil.patch'
    'gpu.patch'
    'temperature.patch'
)
sha256sums=(
    '4da135cd775f4b1022ae29e19ddf16bd6088a836b2e829eb27c1057835d3f817'
    '27ff8f316f0cab362b932e41751af78f2aa2e3a9426e918d99d3230d24662291'
    '75b3456a84d84746136e2ec8d995c7595ff2aa99fe2bcedf80e560edff302dde'
    '32e08c2a5e59b70f8219533a91720cd3224407b41de9aa8c005c451241e7eae2'
    'd6c3203d097e711312cfe31e2d77cd35649a456ad965eaba44b65f71408d999a'
)

pkgver() {
    cd "${srcdir}/${pkgname}"
    git describe --long --tags --abbrev=7 | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
    cd "${srcdir}/${pkgname}"
    patch --forward --strip=1 --input="${srcdir}/gammastep.patch"
    patch --forward --strip=1 --input="${srcdir}/ddcutil.patch"
    patch --forward --strip=1 --input="${srcdir}/gpu.patch"
    patch --forward --strip=1 --input="${srcdir}/temperature.patch"
}

build() {
    cd "${srcdir}/${pkgname}"
    rm -rf "${srcdir}/build"
    meson --prefix=/usr "${srcdir}/build" -Dcava=disabled
    ninja -C "${srcdir}/build"
}

package() {
    cd "${srcdir}/${pkgname}"
    DESTDIR="$pkgdir" ninja -C "${srcdir}/build" install
    install -Dm644 LICENSE -t "$pkgdir/usr/share/licenses/$pkgname/"
}
