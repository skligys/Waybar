# Maintainer: Skirmantas Kligys <Skirmantas.Kligys@gmail.com>

pkgname=waybar-git-sk
pkgver=r948.e9b0365
pkgrel=1
pkgdesc='Highly customizable Wayland bar for Sway and Wlroots based compositors (GIT), with SK patches'
arch=('x86_64')
url="https://github.com/Alexays/Waybar/"
license=('MIT')
provides=('waybar')
conflicts=('waybar')
depends=(
    'gtkmm3'
    'libjsoncpp.so'
    'libsigc++'
    'fmt'
    'jack' 'libjack.so'
    'wayland'
    'libdate-tz.so'
    'libspdlog.so'
    'gtk-layer-shell'
    'libupower-glib.so'
    'upower'
    'libevdev'
    'libinput'
    'libpulse'
    'spdlog'
    'libnl'
    'libappindicator-gtk3'
    'libdbusmenu-gtk3'
    'libmpdclient'
    'libsndio.so'
    'libxkbcommon'
    'libwireplumber'
    'playerctl'
    # SK added:
    'gammastep'
    'ddcutil'
)
makedepends=(
    'cmake'
    'catch2'
    'meson'
    'scdoc' # For generating manpages
    'wayland-protocols'
)
backup=(
    etc/xdg/waybar/config
    etc/xdg/waybar/style.css
)
optdepends=(
    'otf-font-awesome: Icons in the default configuration'
)
source=(
    "${pkgname}::git+https://github.com/Alexays/Waybar#commit=cad18f39f51fdbd93d3236572c8f18728b3a0930"
    'gammastep.patch'
    'ddcutil.patch'
    'gpu.patch'
    'temperature.patch'
)
sha256sums=(
    '11a4cfd97b99a09e030f37148c2e68ed05a9e1340ad3bd94d869b5bcc1369bd0'
    '019c03900e8b6bc2a3f2b4d485baf79ff068b988bd8521d7a6a4960fe9a369d1'
    '71af9d0b60696c4d425686924347d72ee801813b57fa26d40aebb030cb8a5a96'
    '8afb7180bd27cad191e8cc99f6e79766c3da60515147c3770a618831619462b6'
    '748e551e5a7bc8de6a177ea7d56425f57c5dc6cf65eb3a105afef69c38adff83'
)

pkgver() {
    cd "${srcdir}/${pkgname}"
    git describe --long --tags --abbrev=7 | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
    cd "${srcdir}/${pkgname}"
    patch --forward --strip=1 --input="${srcdir}/gammastep.patch"
    patch --forward --strip=1 --input="${srcdir}/ddcutil.patch"
    patch --forward --strip=1 --input="${srcdir}/gpu.patch"
    patch --forward --strip=1 --input="${srcdir}/temperature.patch"
}

build() {
    cd "${srcdir}/${pkgname}"
    rm -rf "${srcdir}/build"
    meson --prefix=/usr "${srcdir}/build" -Dcava=disabled
    ninja -C "${srcdir}/build"
}

package() {
    cd "${srcdir}/${pkgname}"
    DESTDIR="$pkgdir" ninja -C "${srcdir}/build" install
    install -Dm644 LICENSE -t "$pkgdir/usr/share/licenses/$pkgname/"
}
