# Maintainer: Skirmantas Kligys <Skirmantas.Kligys@gmail.com>

pkgname=waybar-git-sk
pkgver=r948.e9b0365
pkgrel=1
pkgdesc='Highly customizable Wayland bar for Sway and Wlroots based compositors (GIT), with SK patches'
arch=('x86_64')
url="https://github.com/Alexays/Waybar/"
license=('MIT')
provides=('waybar')
conflicts=('waybar')
depends=(
    'gtkmm3'
    'libjsoncpp.so'
    'libsigc++'
    'fmt'
    'jack' 'libjack.so'
    'wayland'
    'libdate-tz.so'
    'libspdlog.so'
    'gtk-layer-shell'
    'libupower-glib.so'
    'upower'
    'libevdev'
    'libinput'
    'libpulse'
    'spdlog'
    'libnl'
    'libappindicator-gtk3'
    'libdbusmenu-gtk3'
    'libmpdclient'
    'libsndio.so'
    'libxkbcommon'
    'libwireplumber'
    'playerctl'
    # SK added:
    'gammastep'
)
makedepends=(
    'cmake'
    'catch2'
    'meson'
    'scdoc' # For generating manpages
    'wayland-protocols'
)
backup=(
    etc/xdg/waybar/config
    etc/xdg/waybar/style.css
)
optdepends=(
    'otf-font-awesome: Icons in the default configuration'
)
source=(
    "${pkgname}::git+https://github.com/Alexays/Waybar#commit=3a321d934dda790f8ce8dc76d8e545abe1ec3251"
    'gammastep.patch'
)

sha256sums=(
    'c10e7de307e54177676430f5fbf217ae037f6408334247f3e163bbd97098c4d9'
    'df52e13a360c1af70a487aa6768e1e6815835ad1b8e93a74b58e35fe978a939d'
)

pkgver() {
    cd "${srcdir}/${pkgname}"
    git describe --long --tags --abbrev=7 | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
    cd "${srcdir}/${pkgname}"
    patch --forward --strip=1 --input="${srcdir}/gammastep.patch"
}

build() {
    cd "${srcdir}/${pkgname}"
    rm -rf "${srcdir}/build"
    meson --prefix=/usr "${srcdir}/build" -Dcava=disabled
    ninja -C "${srcdir}/build"
}

package() {
    cd "${srcdir}/${pkgname}"
    DESTDIR="$pkgdir" ninja -C "${srcdir}/build" install
    install -Dm644 LICENSE -t "$pkgdir/usr/share/licenses/$pkgname/"
}
