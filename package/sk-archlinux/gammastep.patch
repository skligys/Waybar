From 4603a7c36bd6e74aa7b5a0bac57c22fda48c71ea Mon Sep 17 00:00:00 2001
From: Skirmantas Kligys <Skirmantas.Kligys@gmail.com>
Date: Fri, 3 Jan 2025 14:11:19 -0800
Subject: [PATCH 2/2] Gammastep module keeps polling for gammastep processes,
 kills children better to stop them from becoming zombies.

---
 include/modules/gammastep.hpp |  3 +++
 resources/config.jsonc        |  3 ++-
 src/modules/gammastep.cpp     | 26 +++++++++++++++++++-------
 3 files changed, 24 insertions(+), 8 deletions(-)

diff --git a/include/modules/gammastep.hpp b/include/modules/gammastep.hpp
index 688d15d4..43da0c7c 100644
--- a/include/modules/gammastep.hpp
+++ b/include/modules/gammastep.hpp
@@ -2,6 +2,7 @@
 
 #include "ALabel.hpp"
 #include "bar.hpp"
+#include "util/sleeper_thread.hpp"
 
 namespace waybar::modules {
 
@@ -13,10 +14,12 @@ class Gammastep : public ALabel {
 
  private:
   bool handleToggle(GdkEventButton* const& e);
+  void killChildProcess();
 
   const Bar&                    bar_;
   int32_t                       pid_;
   std::string                   status_;
+  util::SleeperThread thread_;
 };
 
 }  // namespace waybar::modules
diff --git a/resources/config.jsonc b/resources/config.jsonc
index 63a2fae0..df79d28d 100644
--- a/resources/config.jsonc
+++ b/resources/config.jsonc
@@ -108,7 +108,8 @@
         "format-icons": {
             "activated": "",
             "deactivated": ""
-        }
+        },
+        "interval": 5
     },
     "tray": {
         // "icon-size": 21,
diff --git a/src/modules/gammastep.cpp b/src/modules/gammastep.cpp
index c4433a51..b991bb5c 100644
--- a/src/modules/gammastep.cpp
+++ b/src/modules/gammastep.cpp
@@ -11,18 +11,30 @@ waybar::modules::Gammastep::Gammastep(const std::string& id, const Bar& bar,
       status_("deactivated") {
   pid_ = util::command::processByName("gammastep");
   if (pid_ >= 0) status_ = "activated";
+
   event_box_.add_events(Gdk::BUTTON_PRESS_MASK);
   event_box_.signal_button_press_event().connect(sigc::mem_fun(*this, &Gammastep::handleToggle));
-  dp.emit();
+  thread_ = [this] {
+    dp.emit();
+    thread_.sleep_for(interval_);
+  };
 }
 
 waybar::modules::Gammastep::~Gammastep() {
-  if (pid_ > 0) {
-    kill(-pid_, 9);
-  }
+  if (pid_ > 0) killChildProcess();
+}
+
+auto waybar::modules::Gammastep::killChildProcess() -> void {
+  killpg(pid_, SIGTERM);
+  waitpid(pid_, NULL, 0);
+  pid_ = -1;
+  status_ = "deactivated";
 }
 
 auto waybar::modules::Gammastep::update() -> void {
+  pid_ = util::command::processByName("gammastep");
+  status_ = pid_ >= 0 ? "activated" : "deactivated";
+
   label_.set_markup(
       fmt::format(fmt::runtime(format_), fmt::arg("status", status_), fmt::arg("icon", getIcon(0, status_))));
   label_.get_style_context()->add_class(status_);
@@ -35,14 +47,14 @@ bool waybar::modules::Gammastep::handleToggle(GdkEventButton* const& e) {
   if (e->button == 1) {
     label_.get_style_context()->remove_class(status_);
     if (pid_ > 0) {
-      kill(-pid_, 9);
-      pid_ = -1;
-      status_ = "deactivated";
+      killChildProcess();
     } else {
       pid_ = util::command::forkExec("gammastep -m wayland");
       status_ = "activated";
     }
   }
+  // Delay updates a bit to let the process start/stop.
+  thread_.sleep_for(std::chrono::seconds(1));
   ALabel::handleToggle(e);
   return true;
 }
-- 
