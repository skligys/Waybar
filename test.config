{
    "output": "HDMI-A-1",
    "layer": "top", // Waybar at top layer
    "height": 16,
    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "wlr/taskbar"
    ],
    "modules-center": [],
    "modules-right": [
        "idle_inhibitor",
        "gammastep",
        "gamemode",
        "ddcutil",
        "pulseaudio",
        "network",
        "gpu",
        "cpu",
        "temperature",
        "memory",
        "clock",
        "tray"
    ],
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "wlr/taskbar": {
        "all-outputs": true,
        "format": "{icon}",
        "icon-size": 16,
        "icon-theme": "hicolor",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
        // "ignore-list": [
        //     "Alacritty"
        // ]
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        }
    },
    "gammastep": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ćć",
            "deactivated": "´ćů"
        },
        "interval": 5
    },
    "ddcutil": {
        "format": "{status} ­čĺ╗",
        "bus": 8,
        "interval": 5,
        "input-names": {
             "0x0F": "DP2",
             "0x10": "DP1",
             "0x11": "HDMI1",
             "0x12": "HDMI2",
        },
        "primary-input": "DP1",
        "secondary-input": "DP2"
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "timezones": ["America/Los_Angeles"],
        "format": "{:%m/%d %I:%M %p} ´ÇŚ ",
        "format-alt": "{:%a %Y-%m-%d %I:%M %p} ´ÇŚ ",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "on-scroll": -1,
            "on-click-right": "mode",
            "mode-mon-col": 3,
            "format": {
                "months": "<span size='large' weight='normal' face='Verdana'>{}</span>",
                "weekdays": "<span color='#003399'>{}</span>",
                "today": "<span color='red'><b>{}</b></span>",
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "cpu": {
        "format": "{usage}% ´őŤ",
        "format-alt": "{avg_frequency}/{max_frequency} {usage}% ´őŤ",
        "interval": 10,
        "tooltip": true
    },
    "temperature": {
        // "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["´Łź", "´őë", "´Łę"],
        "tooltip-format": "{name}: {temperatureC}┬░C",
    },
    "memory": {
        "format": "{}% ´âë"
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "interval": 5,
        "format-wifi": "{essid} ({signalStrength}%) ´çź",
        "format-ethernet": "{ipaddr} ´×ľ",
        "format-linked": "{ifname} (No IP) ´×ľ",
        "format-disconnected": "Disconnected ÔÜá",
        "format-alt": "{ifname}: {bandwidthUpBits}Ôľ▓ {bandwidthDownBits}Ôľ╝",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}, {bandwidthUpBits}Ôľ▓ {bandwidthDownBits}Ôľ╝"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
        "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
        "format-muted": "´Üę {format_source}",
        "format-source": "{volume}% ´ä░",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´Çž", "´ÇĘ"]
        },
        "on-click": "pavucontrol",
        "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },
    "gamemode": {
        "format": "{glyph}",
        "format-alt": "{glyph} {count}",
        "hide-not-running": true,
        "use-icon": true,
        "icon-name": "input-gaming-symbolic",
        "icon-spacing": 4,
        "icon-size": 16,
        "tooltip": true,
        "tooltip-format": "Games running: {count}"
    },
    "gpu": {
        "hwmon-path": "/sys/class/drm/card0/device/hwmon/hwmon0",
        "format": "G {busy}% {temperature_c}┬░C {fan_krpms:.1f}Ôč│",
        "interval": 5
    }
}
